{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://paper-to-prototype.local/schema/extraction_schema.json",
  "title": "MethodExtraction",
  "description": "Future GPT-5.6 structured paper analysis. This is data, never executable code.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_title",
    "arxiv_id",
    "method_name",
    "method_family",
    "one_liner",
    "steps",
    "parameters",
    "inputs",
    "outputs",
    "visualization_type",
    "interaction_type",
    "confidence"
  ],
  "properties": {
    "paper_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "arxiv_id": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}\\.[0-9]{4,5}(v[0-9]+)?$"
    },
    "method_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "method_family": {
      "type": "string",
      "enum": [
        "kmeans",
        "astar",
        "scaled_dot_product_attention",
        "unsupported"
      ],
      "description": "A semantic classification. Trusted application code maps supported values to engines."
    },
    "one_liner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "steps": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "parameters": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "$ref": "#/definitions/parameter"
      }
    },
    "inputs": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "outputs": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "visualization_type": {
      "type": "string",
      "enum": ["scatter", "grid", "heatmap", "unsupported"],
      "description": "Semantic suggestion only; it is not an engine or component identifier."
    },
    "interaction_type": {
      "type": "string",
      "enum": [
        "step_through",
        "play_button_animation",
        "live_recompute",
        "unsupported"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  },
  "definitions": {
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "type", "default", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,39}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "type": {
          "type": "string",
          "enum": ["number", "integer", "boolean", "select"]
        },
        "default": {},
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "step": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "enum": ["number", "integer"] } }
          },
          "then": {
            "required": ["min", "max", "step"],
            "properties": { "default": { "type": "number" } }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "boolean" } }
          },
          "then": {
            "properties": { "default": { "type": "boolean" } }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "select" } }
          },
          "then": {
            "required": ["options"],
            "properties": { "default": { "type": "string" } }
          }
        }
      ]
    }
  }
}
