{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-to-prototype.local/schema/method-analysis.schema.json",
  "title": "MethodAnalysis",
  "description": "Validated structured method analysis. This is untrusted data, never executable code.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "arxiv_id",
    "paper_title",
    "authors",
    "method_name",
    "one_liner",
    "learning_goal",
    "steps",
    "parameters",
    "detected_method_family",
    "compatibility",
    "supported_lab_slug",
    "match_reason",
    "confidence",
    "evidence",
    "limitations"
  ],
  "properties": {
    "arxiv_id": {
      "type": "string",
      "pattern": "^(?:(?:07(?:0[4-9]|1[0-2])|(?:0[89]|1[0-4])(?:0[1-9]|1[0-2]))\\.(?:[1-9][0-9]{3}|[0-9][1-9][0-9]{2}|[0-9]{2}[1-9][0-9]|[0-9]{3}[1-9])|(?:1[5-9]|[2-9][0-9])(?:0[1-9]|1[0-2])\\.(?:[1-9][0-9]{4}|[0-9][1-9][0-9]{3}|[0-9]{2}[1-9][0-9]{2}|[0-9]{3}[1-9][0-9]|[0-9]{4}[1-9]))(?:v[1-9][0-9]*)?$"
    },
    "paper_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      }
    },
    "method_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "one_liner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "learning_goal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    },
    "steps": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "detected_method_family": {
      "type": "string",
      "enum": [
        "kmeans_clustering",
        "astar_search",
        "scaled_dot_product_attention",
        "other"
      ]
    },
    "compatibility": {
      "type": "string",
      "enum": ["supported", "unsupported"]
    },
    "supported_lab_slug": {
      "enum": ["kmeans", "astar", "attention", null]
    },
    "match_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    }
  },
  "$defs": {
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "meaning", "effect"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "meaning": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "effect": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paper_section", "page_number", "paraphrased_support"],
      "properties": {
        "paper_section": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "page_number": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "paraphrased_support": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        }
      }
    }
  }
}
