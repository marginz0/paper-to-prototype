    "validate:schema": "node scripts/validate-schema.mjs",
    "scan:forbidden": "node scripts/check-forbidden-runtime.mjs"
  },
  "dependencies": {
    "next": "15.5.9",
    "openai": "6.48.0",
    "react": "19.1.5",
