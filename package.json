  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.14",
    "@types/node": "24.10.1",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "eslint": "9.34.0",
    "eslint-config-next": "15.5.9",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.14",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "overrides": {
    "@types/estree": "1.0.8"
